#include <iostream>
using namespace std;
#define N 3
__global__ void matMul(int *a, int *b, int *c) {
    int row = blockIdx.y * blockDim.y + threadIdx.y;
    int col = blockIdx.x * blockDim.x + threadIdx.x;
    if (row < N && col < N) {
        int sum = 0;
        for (int k = 0; k < N; k++)
            sum += a[row*N+k] * b[k*N+col];
        c[row*N+col] = sum;
    }
}
